# Agent Vibes — environment configuration
# Copy to .env.local to customize (optional)
#
# Zero-config for local dev. Configure for server deployment.

# ── Account Files ───────────────────────────────────────────────────────
# Default credentials directory: ~/.agent-vibes/data/
# Optional per-backend explicit file overrides:
# AGENT_VIBES_ANTIGRAVITY_ACCOUNTS_PATH=/abs/path/antigravity-accounts.json
# AGENT_VIBES_CODEX_ACCOUNTS_PATH=/abs/path/codex-accounts.json
# AGENT_VIBES_OPENAI_COMPAT_ACCOUNTS_PATH=/abs/path/openai-compat-accounts.json
# AGENT_VIBES_CLAUDE_API_ACCOUNTS_PATH=/abs/path/claude-api-accounts.json

# ── Server ──────────────────────────────────────────────────────────────
PORT=2026
# PROXY_API_KEY=your-secret-key
# Verbose logging: use `npm run start:debug` or set LOG_DEBUG=true

# ── Antigravity Backend ─────────────────────────────────────────────────
# Credentials: ~/.agent-vibes/data/antigravity-accounts.json
# Synced via `agent-vibes sync --ide|--tools`
ANTIGRAVITY_STORAGE=~/.protocol-bridge
# Default is false: do not probe Google upstream during bridge startup.
# When false, startup only inspects local worker/account presence and keeps
# default Gemini models until a real Google request or explicit model refresh.
# AGENT_VIBES_GOOGLE_STARTUP_UPSTREAM_CHECK=false
# Optional: path to Antigravity.app bundle. If unset, common macOS locations are probed.
# ANTIGRAVITY_APP_PATH=/Applications/Antigravity.app

# ── Codex Backend (GPT / O-series Models) ───────────────────────────────
# Credentials: ~/.agent-vibes/data/codex-accounts.json
# Synced via `agent-vibes sync --codex`
# Codex upstream endpoint (default: chatgpt.com Codex API)
# CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
# Optional HTTP/HTTPS/SOCKS5 proxy for Codex requests
# CODEX_PROXY_URL=socks5://127.0.0.1:1080
# WebSocket transport: lower latency, session reuse, auto-fallback to HTTP
# Default is enabled. Set to false to force legacy HTTP streaming.
# CODEX_USE_WEBSOCKET=true

# ── OpenAI-Compatible Backend (Third-party GPT APIs) ─────────────────────
# Credentials: ~/.agent-vibes/data/openai-compat-accounts.json (manual edit)
# Responses API routing mode: auto (default) | always | never
# OPENAI_COMPAT_USE_RESPONSES_API=auto

# ── Claude API Backend (Third-party Claude-Compatible APIs) ───────────────
# Credentials: ~/.agent-vibes/data/claude-api-accounts.json
# Manual edit or `agent-vibes sync --claude`
# Single-account env fallback (optional)
# CLAUDE_API_KEY=sk-ant-xxx
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_PROXY_URL=socks5://127.0.0.1:1080
# CLAUDE_FORCE_MODEL_PREFIX=false
